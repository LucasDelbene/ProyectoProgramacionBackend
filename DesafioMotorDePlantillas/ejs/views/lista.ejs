<!DOCTYPE html>
<html lang="en">
    
  <%- include('head') %>
 
<body class="bg-dark">
    <h1 class="text-light m-3 me-auto">LISTA DE PRODUCTOS</h1>
 
    <% if(productos.length > 0){ %>
        <div class="table-responsive">
            <table class="table table-dark">
                <tr>
                    <th class="text-center text-light">ID</th>
                    <th class="text-center text-light">NOMBRE</th>
                    <th class="text-center text-light">PRECIO</th>
                    <th class="text-center text-light">IMAGEN URL</th>
                </tr>
                <% for (producto of productos) {%>
                <tr>
                    <td class="text-center text-light">#<%= producto.id %></td>
                    <td class="text-center text-light"><%= producto.nombre %></td>
                    <td class="text-center text-light">$<%= producto.precio %></td>
                    <td><img src="<%= producto.imagen %>" width="100px"/></td>
                </tr>
                <% } %>
            </table>
        </div>
    <% } else { %>
        <h2 class="alert alert-danger">NO HAY PRODUCTOS EN LA LISTA</h2>
    <% } %>
    <a href="formulario"><button class="btn btn-outline-light">REGRESAR AL FORMULARIO</button></a>
</body>
</html>