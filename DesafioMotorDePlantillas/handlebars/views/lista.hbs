{{#> body}}
 <h2 class="text-light m-3 me-auto">LISTA DE PRODUCTOS</h2>
 <br>
 {{#if productos}}
  <div class="table-responsive">
    <table class="table table-dark">
        <tr>
            <th class="text-center text-light">ID</th>
            <th class="text-center text-light">NOMBRE</th>
            <th class="text-center text-light">PRECIO</th>
            <th class="text-center text-light">IMAGEN URL</th>
        </tr>

        {{#each productos}}
         <tr>
            <td class="text-center text-light">{{this.id}}</td>
            <td class="text-center text-light">{{this.nombre}}</td>
            <td class="text-center text-light">{{this.precio}}</td>
            <td><img src="{{this.imagen}}" width="100px"/></td>
         </tr>
        {{/each}}
    </table>
  </div>
 {{else}}
 <h2 class="alert alert-danger">NO HAY PRODUCTOS EN LA LISTA</h2>
 {{/if}}
 <a href="./formulario.hbs"><button class="btn btn-outline-light">REGRESAR AL FORMULARIO</button></a>
{{/body}}
